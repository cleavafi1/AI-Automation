# Supabase project credentials
# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API Keys in the Supabase dashboard).
# Uses the new key format: sb_publishable_... and sb_secret_...

# Public project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — safe for the browser.
# Not consumed by Phase 1 code yet; reserved for a client-side Supabase
# client in Phase 2. Fine to leave blank for now.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — SERVER ONLY, never expose to the client.
# Used by the API route to insert inquiries, bypassing RLS.
SUPABASE_SECRET_KEY=

# Anthropic API key (SERVER ONLY) — used by the quote-generation logic (Phase 2).
# Get it from https://console.anthropic.com -> Settings -> API Keys.
ANTHROPIC_API_KEY=

# Resend email (SERVER ONLY). API key from https://resend.com -> API Keys.
RESEND_API_KEY=

# Verified sender address for outgoing email, e.g. info@cleava.fi.
# Read directly by lib/email.ts — there is no hardcoded fallback, so sends
# throw if this is unset.
EMAIL_FROM_ADDRESS=

# Admin login (SERVER ONLY). Single admin account.
# ADMIN_EMAIL      — the login email/username.
# ADMIN_PASSWORD_HASH — a bcrypt hash of the password, base64-encoded (NOT
#   plaintext). It MUST be base64: a raw bcrypt hash contains "$" chars that
#   Next.js's dotenv-expand corrupts. The script below outputs the correct form.
#   Generate with:  node scripts/hash-password.mjs "your-password"
# ADMIN_SESSION_SECRET — random secret used to sign the session cookie.
#   Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Google Calendar (SERVER ONLY) — Phase 5 availability + booking.
# GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 — the FULL service-account JSON key,
#   base64-encoded (same safe pattern as ADMIN_PASSWORD_HASH / DKIM keys: never
#   store the raw JSON in the repo). At runtime lib/calendar.ts decodes it back
#   into the credentials object. Generate with:
#     base64 -w0 service-account.json         # Linux
#     certutil -encode service-account.json tmp && findstr /v /c:- tmp   # Windows
#   Then share the target calendar with the service account's client_email
#   (Calendar settings → Share with specific people → Make changes to events).
# GOOGLE_CALENDAR_ID — the calendar to read/write (the Cleava booking calendar).
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_CALENDAR_ID=cleavafi@gmail.com

# Telegram staff approval bot (SERVER ONLY) — Phase 6.
# TELEGRAM_BOT_TOKEN — create a bot with @BotFather and paste its token.
# TELEGRAM_STAFF_CHAT_ID — the chat/group id the bot notifies and accepts
#   approve/decline/edit actions from. Only updates from this chat are honored.
#   Find it by messaging the bot then reading the getUpdates response, or via
#   @userinfobot. After deploying, register the webhook (see README Phase 6):
#     curl "https://api.telegram.org/bot<TOKEN>/setWebhook?url=https://<host>/api/telegram/webhook"
TELEGRAM_BOT_TOKEN=
TELEGRAM_STAFF_CHAT_ID=
