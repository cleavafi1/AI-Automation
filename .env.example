# Supabase project credentials
# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings -> API in the Supabase dashboard).

# Public project URL, e.g. https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe for the browser).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key (SERVER ONLY — never expose to the client).
# Used by the API route to insert inquiries, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=
